# Upstash Redis — get from upstash.com (free tier works)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Resend — get from resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@yourdomain.com

# Random secret for the cron endpoint — generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# WAF token solver (scripts/waf-solver, runs in GitHub Actions).
# Any valid guest.dealer.toyota.com v-spec link — used as a seed to mint the
# shared AWS WAF token. The token is dealer/VIN-agnostic.
# Set this as a GitHub Actions secret (SEED_VSPEC_URL), not in the Vercel app.
SEED_VSPEC_URL=https://guest.dealer.toyota.com/v-spec/20122/5TDADAB5XTS046993/detail?k=...
